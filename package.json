{
  "name": "pet-ride",
  "version": "0.1.0",
  "private": true,
  "description": "App estilo Uber para transporte de pets — PWA responsivo",
  "author": "Aldo Ribeiro <aldorip@github.com>",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @pet-ride/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @pet-ride/api exec prisma generate",
    "db:studio": "pnpm --filter @pet-ride/api exec prisma studio",
    "db:seed": "pnpm --filter @pet-ride/api exec prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
