# ================================
# PetRide — Variáveis de Ambiente
# ================================

# App
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000
DRIVER_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://petride:petride@localhost:5432/petride_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=petride
DB_PASS=petride
DB_NAME=petride_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-access-token
MERCADO_PAGO_PUBLIC_KEY=TEST-your-public-key
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret

# PIX (via Mercado Pago ou outra PSP)
PIX_KEY=your_pix_key

# Upload de imagens (S3 / R2 / MinIO)
STORAGE_ENDPOINT=https://seu-bucket.r2.cloudflarestorage.com
STORAGE_BUCKET=pet-ride
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_REGION=auto

# Email (Resend)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@petride.app

# SMS / WhatsApp (Evolution API)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_key
EVOLUTION_INSTANCE=petride

# Admin
ADMIN_EMAIL=admin@petride.app
ADMIN_PASSWORD=change_me_strong_password
